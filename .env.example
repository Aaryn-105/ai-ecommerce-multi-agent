# LLM API 配置（DeepSeek 示例，兼容 OpenAI 格式的均可）
OPENAI_API_KEY=sk-your-deepseek-api-key
LLM_MODEL_NAME=deepseek-chat
LLM_API_BASE=https://api.deepseek.com

# 数据库配置（开发默认 SQLite）
DATABASE_URL=sqlite:///./data/app.db

# 生产 PostgreSQL 示例（切换时取消注释）
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ecommerce_agents

# FakeStore API 配置
FAKESTORE_API_BASE=https://fakestoreapi.com

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true